<?xml version="1.0" encoding="utf-8" ?>
<!--
    ChannelCard.xml - Focusable channel card (mirrors tvOS ChannelCardView)

    Coordinate space: HD 1280x720 (all values scaled 2/3 from original FHD design)

    Card anatomy (240 x 230):
      [0-127]  Thumbnail area with dark bg + icon letter
      [99-120] LIVE badge (coral pill, 76px wide centered)
      [131-167] Channel name (bold, turns coral when focused)
      [170-220] Channel subtitle (muted gray, wraps to 2 lines)

    Focus state: darker bg + coral name text + coral border outline
-->
<component name="ChannelCard" extends="Group" focusable="true">
    <interface>
        <field id="channelName"     type="string"  onChange="onDataChange" />
        <field id="channelSubtitle" type="string"  onChange="onDataChange" />
        <field id="iconText"        type="string"  onChange="onDataChange" />
        <field id="isFocused"       type="boolean" value="false" onChange="onFocusChange" />
    </interface>

    <children>

        <!-- Outer card background -->
        <Rectangle id="cardBg"
            width="240" height="230"
            color="#636D72FF"
            blendingEnabled="true" />

        <!-- Coral border (visible when focused) -->
        <Rectangle id="borderTop"    width="240" height="2"   color="#00000000" translation="[0, 0]" />
        <Rectangle id="borderBottom" width="240" height="2"   color="#00000000" translation="[0, 228]" />
        <Rectangle id="borderLeft"   width="2"   height="230" color="#00000000" translation="[0, 0]" />
        <Rectangle id="borderRight"  width="2"   height="230" color="#00000000" translation="[238, 0]" />

        <!-- Thumbnail area background -->
        <Rectangle id="thumbBg"
            width="240" height="127"
            color="#4A5459FF"
            translation="[0, 0]" />

        <!-- Channel icon letter (large, centered in thumbnail) -->
        <Label id="iconLabel"
            width="240" height="87"
            horizAlign="center" vertAlign="center"
            translation="[0, 7]"
            color="#FFFFFFFF"
            font="font:LargeSystemFont" />

        <!-- LIVE badge background (coral) -->
        <Rectangle id="liveBadgeBg"
            width="76" height="21"
            color="#FF5F62FF"
            translation="[82, 99]" />

        <!-- LIVE badge text -->
        <Label id="liveLabel"
            width="76" height="21"
            text="• LIVE"
            horizAlign="center" vertAlign="center"
            translation="[82, 99]"
            color="#FFFFFFFF"
            font="font:SmallBoldSystemFont" />

        <!-- Channel name -->
        <Label id="nameLabel"
            width="224" height="36"
            horizAlign="center" vertAlign="center"
            translation="[8, 131]"
            color="#FFFFFFFF"
            font="font:MediumBoldSystemFont" />

        <!-- Channel subtitle -->
        <Label id="subtitleLabel"
            width="224" height="50"
            horizAlign="center" vertAlign="center"
            translation="[8, 170]"
            color="#999999FF"
            font="font:SmallSystemFont" />

    </children>
    <script type="text/brightscript" uri="ChannelCard.brs" />
</component>
