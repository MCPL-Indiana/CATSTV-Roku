<?xml version="1.0" encoding="utf-8" ?>
<!--
    ChannelCard.xml - Full-image channel card

    Card image (270x220 PNG) contains the background, icon, LIVE badge,
    channel name, and subtitle. Focus state adds a coral border outline.
-->
<component name="ChannelCard" extends="Group">
    <interface>
        <field id="channelName"     type="string"  onChange="onDataChange" />
        <field id="channelSubtitle" type="string"  onChange="onDataChange" />
        <field id="iconImage"       type="string"  onChange="onDataChange" />
        <field id="isFocused"       type="boolean" value="false" onChange="onFocusChange" />
    </interface>

    <children>

        <!-- Full-card image (270x220 PNG with all content baked in) -->
        <Poster id="cardPoster"
            width="270" height="220"
            loadDisplayMode="noScale"
            translation="[0, 0]" />

        <!-- Coral focus border — invisible until focused -->
        <Rectangle id="borderTop"    width="270" height="3"   color="#00000000" translation="[0, 0]" />
        <Rectangle id="borderBottom" width="270" height="3"   color="#00000000" translation="[0, 217]" />
        <Rectangle id="borderLeft"   width="3"   height="220" color="#00000000" translation="[0, 0]" />
        <Rectangle id="borderRight"  width="3"   height="220" color="#00000000" translation="[267, 0]" />

    </children>
    <script type="text/brightscript" uri="ChannelCard.brs" />
</component>
