<?xml version="1.0" encoding="utf-8" ?>
<!--
    HomeScreen.xml - Channel selection + Recent Videos browser
    (mirrors tvOS ContentView: banner → live channels → three video sections)

    Coordinate space: HD 1280×720

    Layout — contentGroup scrolls vertically:
      [y=0]    channels4_banner.jpg (1280×212)
      [y=222]  "WATCH CATS " + "LIVE" heading
      [y=266]  Subtitle: "Select a channel to start watching"
      [y=300]  4 channel cards (270×220), x=60, 357, 654, 951
      [y=530]  separator line (1160×2)
      [y=538]  "MOST RECENT VIDEOS" heading (coral)
      [y=580]  Government Meetings VideoRow
      [y=784]  Community Videos VideoRow
      [y=988]  CATSWeek VideoRow

    Vertical scroll positions (contentGroup.translation.y):
      0    → channels section visible; banner at top
      -528 → "MOST RECENT VIDEOS" lands at y=10; video rows fill y=52–692
-->
<component name="HomeScreen" extends="Group" handlesBack="false">
    <interface>
        <field id="channelSelected" type="assocarray" alwaysNotify="true" />
        <field id="videoSelected"   type="assocarray" alwaysNotify="true" />
    </interface>

    <children>

        <!-- ── Full-screen background ── -->
        <Rectangle id="bg" width="1280" height="720" color="#282C2FFF" />

        <!-- ── Scrollable content group ──────────────────────────────────────
             BrightScript animates translation.y between 0 and -528.         -->
        <Group id="contentGroup">

            <!-- ── Banner image (mirrors tvOS ChannelsBanner at top of scroll) ── -->
            <Poster id="bannerImage"
                width="1280" height="212"
                loadDisplayMode="scaleToFit"
                translation="[0, 0]" />

            <!-- "WATCH CATS" (white) + "LIVE" (coral) — centered by BrightScript -->
            <Label
                id="watchCatsLabel"
                height="40"
                text="WATCH CATS "
                horizAlign="left" vertAlign="center"
                translation="[0, 222]"
                color="#FFFFFFFF"
                font="font:LargeSystemFont" />
            <Label
                id="liveHeadingLabel"
                height="40"
                text="LIVE"
                horizAlign="left" vertAlign="center"
                translation="[0, 222]"
                color="#FF5F62FF"
                font="font:LargeSystemFont" />

            <!-- Subtitle -->
            <Label
                id="subtitleLabel"
                width="800" height="26"
                text="Select a channel to start watching"
                horizAlign="center" vertAlign="center"
                translation="[240, 266]"
                color="#999999FF"
                font="font:SmallSystemFont" />

            <!-- ── Channel cards: x = 60, 357, 654, 951; y = 300 ──
                 4 × 270px + 3 × 27px gap = 1161px; last edge = 951+270 = 1221 < 1226 ✓ -->
            <ChannelCard id="card0" translation="[60,  300]" />
            <ChannelCard id="card1" translation="[357, 300]" />
            <ChannelCard id="card2" translation="[654, 300]" />
            <ChannelCard id="card3" translation="[951, 300]" />

            <!-- ── Divider between live channels and recent videos ── -->
            <Rectangle id="separator"
                width="1160" height="2"
                color="#636D72FF"
                translation="[60, 530]" />

            <!-- ── "MOST RECENT VIDEOS" section heading (coral) ── -->
            <Label
                id="recentLabel"
                width="700" height="34"
                text="MOST RECENT VIDEOS"
                horizAlign="left" vertAlign="center"
                translation="[60, 538]"
                color="#FF5F62FF"
                font="font:SmallBoldSystemFont" />

            <!-- ── Three video rows ── -->
            <VideoRow id="govRow"       translation="[0, 580]" />
            <VideoRow id="communityRow" translation="[0, 784]" />
            <VideoRow id="catsweekRow"  translation="[0, 988]" />

        </Group>
        <!-- ──────────────────────────────────────────────────────────────── -->

        <!-- ── Scroll animation (animates contentGroup.translation) ── -->
        <Animation id="scrollAnim" duration="0.25" easeFunction="outQuad" repeat="false">
            <Vector2DFieldInterpolator
                id="scrollInterp"
                fieldToInterp="contentGroup.translation"
                key="[0.0, 1.0]" />
        </Animation>

    </children>
    <script type="text/brightscript" uri="HomeScreen.brs" />
</component>
