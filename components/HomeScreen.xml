<?xml version="1.0" encoding="utf-8" ?>
<!--
    HomeScreen.xml - Channel selection screen (mirrors tvOS ContentView)

    Coordinate space: HD 1280x720 (ui_resolution=HD in manifest)
    Safe zone: x=54–1226, y=40–680 (~4% from each edge)

      [0-67]   Header bar (bg full-width; text within x=54–1226)
      [153-230] "WATCH CATS / LIVE" heading + subtitle (both centered at x=640)
      [267-547] 4 channel cards: x=60,357,654,951 each 270px wide (ends at 1221 < 1226 ✓)
      [627-720] Footer bar (bg to bottom edge; text within y=633–684 ✓)
-->
<component name="HomeScreen" extends="Group" handlesBack="false">
    <interface>
        <field id="channelSelected" type="assocarray" alwaysNotify="true" />
    </interface>

    <children>

        <!-- ── Background ── -->
        <Rectangle id="bg" width="1280" height="720" color="#282C2FFF" />

        <!-- ── Header bar ── -->
        <Rectangle id="headerBg" width="1280" height="67" color="#1E2224FF" translation="[0, 0]" />
        <!-- x=54 left safe zone; right label ends at 1053+160=1213 < 1226 right safe zone -->
        <Label
            id="logoLabel"
            width="200" height="67"
            text="CATS TV"
            horizAlign="left" vertAlign="center"
            translation="[54, 0]"
            color="#FFFFFFFF"
            font="font:LargeSystemFont" />
        <Label
            id="liveStreamsLabel"
            width="160" height="67"
            text="LIVE STREAMS"
            horizAlign="right" vertAlign="center"
            translation="[1053, 0]"
            color="#FF5F62FF"
            font="font:SmallBoldSystemFont" />

        <!-- ── "WATCH CATS" heading (white) — right-aligns to screen center ── -->
        <Label
            id="watchCatsLabel"
            width="640" height="47"
            text="WATCH CATS"
            horizAlign="right" vertAlign="center"
            translation="[0, 153]"
            color="#FFFFFFFF"
            font="font:LargeSystemFont" />

        <!-- ── "LIVE" heading (coral accent) — left-aligns from screen center ── -->
        <Label
            id="liveHeadingLabel"
            width="200" height="47"
            text=" LIVE"
            horizAlign="left" vertAlign="center"
            translation="[640, 153]"
            color="#FF5F62FF"
            font="font:LargeSystemFont" />

        <!-- ── Subtitle ── -->
        <Label
            id="subtitleLabel"
            width="1280" height="27"
            text="Select a channel to start watching"
            horizAlign="center" vertAlign="center"
            translation="[0, 207]"
            color="#999999FF"
            font="font:MediumSystemFont" />

        <!-- ── Channel cards ──
             4 × 270px wide + 3 × 27px gaps = 1161px total
             Start x=60, step=297; last card ends at 951+270=1221 < 1226 safe zone ✓ -->
        <ChannelCard id="card0" translation="[60, 267]" />
        <ChannelCard id="card1" translation="[357, 267]" />
        <ChannelCard id="card2" translation="[654, 267]" />
        <ChannelCard id="card3" translation="[951, 267]" />

        <!-- ── Footer bar ──
             Background extends to screen bottom (fine for a decoration rect).
             Text within safe zone: org centers at y=647 ✓, address centers at y=670 ✓ -->
        <Rectangle id="footerBg" width="1280" height="93" color="#1A1D1FFF" translation="[0, 627]" />
        <Label
            id="footerOrg"
            width="1280" height="27"
            text="Community Access Television Services"
            horizAlign="center" vertAlign="center"
            translation="[0, 633]"
            color="#999999FF"
            font="font:SmallSystemFont" />
        <Label
            id="footerAddress"
            width="1280" height="27"
            text="303 E. Kirkwood Ave.  •  Bloomington, IN 47408  •  (812) 349-3111"
            horizAlign="center" vertAlign="center"
            translation="[0, 657]"
            color="#6E7377FF"
            font="font:SmallSystemFont" />

    </children>
    <script type="text/brightscript" uri="HomeScreen.brs" />
</component>
