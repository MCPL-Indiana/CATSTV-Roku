<?xml version="1.0" encoding="utf-8" ?>
<!--
    PlayerScreen.xml - Full-screen HLS video player (mirrors tvOS LiveStreamPlayerView)

    Coordinate space: HD 1280x720 (ui_resolution=HD in manifest)
    Safe zone: x=54–1226, y=40–680

    Video node fills the full 1280x720 scene.
    Overlay elements placed within safe zone so overscan doesn't clip them.
    BACK key stops playback and returns to HomeScreen.
-->
<component name="PlayerScreen" extends="Group" handlesBack="true">
    <interface>
        <field id="channelData"  type="assocarray" onChange="onChannelDataChange" />
        <field id="playerClosed" type="boolean"    alwaysNotify="true" />
    </interface>

    <children>

        <!-- Black background, visible while loading -->
        <Rectangle id="bg" width="1280" height="720" color="#000000FF" />

        <!-- Full-screen video (HLS via Roku Video node).
             1280x720 matches ui_resolution=HD. Roku upscales to 1080p/4K if the TV supports it. -->
        <Video id="video" width="1280" height="720" translation="[0, 0]" />

        <!-- ── Channel info overlay (top-left, within safe zone x≥54, y≥40) ── -->
        <Rectangle id="overlayBg"
            width="260" height="40"
            color="#00000099"
            translation="[54, 43]"
            visible="false" />

        <Label id="channelNameLabel"
            width="240" height="40"
            horizAlign="left" vertAlign="center"
            translation="[67, 43]"
            color="#FFFFFFFF"
            font="font:MediumBoldSystemFont"
            visible="false" />

        <!-- ── Loading / error message (centered) ── -->
        <Label id="loadingLabel"
            width="1280" height="720"
            horizAlign="center" vertAlign="center"
            text="Loading stream..."
            color="#FFFFFFFF"
            font="font:LargeSystemFont"
            visible="true" />


    </children>
    <script type="text/brightscript" uri="PlayerScreen.brs" />
</component>
